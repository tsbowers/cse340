<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>
    
    <ul>
        <% projects.forEach(project => { %>
            <% 
                const rawDate = project.project_date || project.date;
                const formattedDate = rawDate 
                    ? new Date(rawDate).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                        timeZone: 'UTC'
                      })
                    : 'Date TBD';
            %>
            <li>
                <strong><%= formattedDate %>:</strong> 
                <a href="/project/<%= project.project_id %>"><%= project.title || 'Untitled Project' %></a> 
                
                <% if (project.organization_id) { %>
                    (<a href="/organization/<%= project.organization_id %>"><%= project.organization_name || 'View Organization' %></a>)
                <% } %>
                
                <p><em>Location: <%= project.project_location || project.location || 'Remote/TBD' %></em> — <%= project.description || '' %></p>
            </li>
        <% }); %>
    </ul>
</main>

<%- include('partials/footer') %>