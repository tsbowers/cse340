<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    
    <section>
        <h2>Service Project Categories</h2>

        <% if (categories && categories.length > 0) { %>
            <ul>
                <% categories.forEach(category => { %>
                    <li><%= category.name %></li>
                <% }); %>
            </ul>
        <% } else { %>
            <p>No categories found at this time.</p>
        <% } %>
    </section>
</main>

<%- include('partials/footer') %>